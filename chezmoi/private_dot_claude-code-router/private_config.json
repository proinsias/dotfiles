{
  "LOG": true,
  "LOG_LEVEL": "info",
  "HOST": "127.0.0.1",
  "PORT": 3456,
  "APIKEY": "$CCR_API_KEY",
  "API_TIMEOUT_MS": 600000,
  "transformers": [],
  "Providers": [
    {
      "name": "gemini",
      "api_base_url": "https://generativelanguage.googleapis.com/v1beta/models/",
      "api_key": "$GEMINI_API_KEY",
      "models": [
        "gemini-2.5-flash",
        "gemini-2.5-pro"
      ],
      "transformer": {
        "use": [
          "gemini"
        ]
      }
    },
    {
      "name": "groq",
      "api_base_url": "https://api.groq.com/openai/v1/chat/completions",
      "api_key": "$GROQ_API_KEY",
      "models": [
        "moonshotai/kimi-k2-instruct"
      ],
      "transformer": {
        "use": [
          ["maxtoken", { "max_tokens": 16384 }]
        ]
      }
    },
    {
      "name": "ollama",
      "api_base_url": "http://localhost:11434/v1/chat/completions",
      "api_key": "ollama",
      "models": ["kimi-k2.5:cloud", "gemini-3-flash-preview:latest", "qwen2.5-coder:14b"]
    }
  ],
  "StatusLine": {
    "enabled": true,
    "currentStyle": "default",
    "default": {
      "modules": [
        {
          "type": "workDir",
          "icon": "󰉋",
          "text": "{{workDirName}}",
          "color": "bright_blue"
        },
        {
          "type": "gitBranch",
          "icon": "🌿",
          "text": "{{gitBranch}}",
          "color": "bright_green"
        },
        {
          "type": "model",
          "icon": "🤖",
          "text": "{{model}}",
          "color": "bright_yellow"
        },
        {
          "type": "usage",
          "icon": "📊",
          "text": "{{inputTokens}} → {{outputTokens}}",
          "color": "bright_magenta"
        },
        {
          "type": "speed",
          "icon": "⚡",
          "text": "{{tokenSpeed}}",
          "color": "bright_green"
        }
      ]
    },
    "powerline": {
      "modules": []
    }
  },
"Router": {
    "default": "gemini,gemini-2.5-flash",
    "background": "ollama,qwen2.5-coder:14b",
    "think": "groq,moonshotai/kimi-k2-instruct",
    "longContext": "gemini,gemini-2.5-pro",
    "longContextThreshold": 60000,
    "webSearch": "",
    "image": "gemini,gemini-2.5-flash"
  },
  "CUSTOM_ROUTER_PATH": ""
}
