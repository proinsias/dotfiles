{
    "mcpServers": {
        "Readwise MCP": {
            "command": "npx",
            "args": [
                "-y",
                "@readwise/readwise-mcp"
            ],
            "env": {
                "ACCESS_TOKEN": {{ onepasswordRead "op://Parents/Readwise/API token" | quote }}
            }
        }
    },
    "preferences": {
        "coworkScheduledTasksEnabled": false,
        "ccdScheduledTasksEnabled": false,
        "sidebarMode": "chat",
        "coworkWebSearchEnabled": true
    }
}
