#!/usr/bin/env bash
set -euo pipefail

REPO="https://github.com/lycheeverse/lychee.git"
CONFIG=".pre-commit-config.yaml"

latest=$(git ls-remote --tags "$REPO" \
    | grep -v '\^{}' \
    | awk '{print $2}' \
    | sed 's|refs/tags/||' \
    | grep '^v[0-9]' \
    | sort -V \
    | tail -1)

if [[ -z "$latest" ]]; then
    echo "error: could not determine latest lychee version" >&2
    exit 1
fi

echo "Latest lychee version: $latest"

if ! grep -q 'rev: nightly' "$CONFIG"; then
    echo "No 'rev: nightly' found in $CONFIG — nothing to update"
    exit 0
fi

sed -i '' "s/rev: nightly/rev: $latest/" "$CONFIG"
echo "Updated $CONFIG: rev: nightly -> rev: $latest"
